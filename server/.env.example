PORT=4000
NODE_ENV=production

# Frontend origins allowed by CORS. Use the CloudFront URL after creating the distribution.
CLIENT_URL=https://your-cloudfront-domain.cloudfront.net
# Optional: comma-separated extra origins, for example local dev or a custom domain.
CORS_ORIGINS=http://localhost:5173,https://your-custom-domain.example.com

# Auth
JWT_SECRET=replace-with-strong-secret
SELLER_EMAIL=admin@example.com
SELLER_PASSWORD=replace-with-strong-password

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net

# Cloudinary
CLOUDINARY_CLOUD_NAME=replace-me
CLOUDINARY_API_KEY=replace-me
CLOUDINARY_API_SECRET=replace-me

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
